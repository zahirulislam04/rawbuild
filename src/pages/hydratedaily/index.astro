        </svg>
        <span class="btn-store-meta">
          <span class="btn-store-small">Download on the</span>
          App Store
        </span>
      </a>
      <p class="note">Free · iPhone · iOS 16+</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════
       ANIMATED BEAR
  ══════════════════════════════════════════════════ -->
