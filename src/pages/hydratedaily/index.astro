---
const title = 'Hydrate Daily - Water Tracker — Your calm hydration companion';
const description = 'Hydrate Daily is a free water & drink intake tracker for iPhone. Log every drink, build daily streaks, and meet your personal hydration goal. No account needed. No subscription.';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://rawbuild.de/hydratedaily" />
  <meta property="og:title" content="Hydrate Daily - Water Tracker">
  <meta property="og:description" content="Water & Drink Intake Reminder. Free for iPhone — no account, no subscription.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://rawbuild.de/hydratedaily">
  <meta name="theme-color" content="#EAF4FB">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #EAF4FB;
      --bg-soft:      #F4F9FD;
      --surface:      #FFFFFF;
      --primary:      #2E87CC;
      --primary-lt:   #7EC8E3;
      --primary-dk:   #1B6FAD;
      --text:         #1B3D5F;
      --text2:        #1F5F84;
      --border:       #C8DFF0;
      --success:      #2ECC9A;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── Header ─────────────────────────────────────── */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 32px;
      max-width: 1000px;
      margin: 0 auto;
    }

    .hdr-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .hdr-icon {
      width: 36px;
      height: 36px;
      background: white;
      border-radius: 9px;
      box-shadow: 0 1px 6px rgba(46,135,204,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .hdr-name {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
    }

    .hdr-cta {
      background: var(--primary);
      color: white;
      text-decoration: none;
      padding: 8px 20px;
      border-radius: 50px;
      font-size: 0.875rem;
      font-weight: 600;
      transition: background 0.15s;
    }
    .hdr-cta:hover { background: var(--primary-dk); }

    /* ── Hero ────────────────────────────────────────── */
    .hero {
      text-align: center;
      padding: 48px 24px 0;
      max-width: 580px;
      margin: 0 auto;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(46,135,204,0.1);
      color: var(--primary);
      border-radius: 50px;
      padding: 5px 14px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 20px;
      animation: fade-up 0.5s ease both;
    }

    .hero-title {
      font-size: clamp(2.2rem, 8vw, 3.4rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.08;
      color: var(--text);
      margin-bottom: 16px;
      animation: fade-up 0.5s 0.08s ease both;
    }
    .hero-title span { color: var(--primary); }

    .hero-sub {
      font-size: clamp(1rem, 3vw, 1.1rem);
      color: var(--text2);
      line-height: 1.65;
      max-width: 400px;
      margin: 0 auto 36px;
      animation: fade-up 0.5s 0.16s ease both;
    }

    .hero-actions {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      animation: fade-up 0.5s 0.24s ease both;
    }

    /* ── App Store button ────────────────────────────── */
    .btn-store {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--text);
      color: white;
      text-decoration: none;
      padding: 13px 26px;
      border-radius: 14px;
      font-size: 1rem;
      font-weight: 600;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn-store:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(27,61,95,0.28);
    }
    .btn-store-meta { text-align: left; }
    .btn-store-small {
      display: block;
      font-size: 0.7rem;
      font-weight: 400;
      opacity: 0.7;
      line-height: 1;
      margin-bottom: 2px;
    }

    .btn-store-lt {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: white;
      color: var(--text);
      text-decoration: none;
      padding: 13px 26px;
      border-radius: 14px;
      font-size: 1rem;
      font-weight: 600;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn-store-lt:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.18);
    }

    .note {
      font-size: 0.8rem;
      color: var(--text2);
      opacity: 0.7;
    }

    /* ── Bear visual ─────────────────────────────────── */
    .bear-wrap {
      display: flex;
      justify-content: center;
      padding: 32px 0 0;
    }

    .bear-visual {
      position: relative;
      width: 220px;
    }

    .bear-visual svg {
      filter: drop-shadow(0 14px 28px rgba(46,135,204,0.22));
      animation: float 4s ease-in-out infinite;
      animation-delay: 3s;
    }

    .bear-shadow {
      position: absolute;
      bottom: -12px;
      left: 50%;
      transform: translateX(-50%);
      width: 130px;
      height: 18px;
      background: radial-gradient(ellipse, rgba(46,135,204,0.18) 0%, transparent 70%);
    }

    /* ── Divider wave ────────────────────────────────── */
    .wave-div {
      width: 100%;
      overflow: hidden;
      line-height: 0;
      margin-top: -1px;
    }
    .wave-div svg { display: block; width: 100%; }

    /* ── Features ────────────────────────────────────── */
    .features-sec {
      background: var(--surface);
      padding: 64px 24px;
    }

    .sec-inner {
      max-width: 880px;
      margin: 0 auto;
    }

    .sec-eyebrow {
      text-align: center;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 10px;
    }

    .sec-heading {
      text-align: center;
      font-size: clamp(1.5rem, 5vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
      margin-bottom: 48px;
    }

    .feat-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    @media (max-width: 660px) {
      .feat-grid { grid-template-columns: 1fr; }
      header { padding: 14px 20px; }
      .hdr-name { display: none; }
    }
    @media (min-width: 661px) and (max-width: 900px) {
      .feat-grid { grid-template-columns: repeat(2, 1fr); }
    }

    .feat-card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 26px 22px;
    }

    .feat-emoji { font-size: 1.9rem; margin-bottom: 12px; }

    .feat-name {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 7px;
    }

    .feat-body {
      font-size: 0.855rem;
      color: var(--text2);
      line-height: 1.55;
    }

    /* ── Why section ─────────────────────────────────── */
    .why-sec {
      padding: 64px 24px;
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
    }

    .why-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 36px;
    }

    .why-item {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 13px 16px;
      text-align: left;
    }

    .why-check {
      width: 22px;
      height: 22px;
      background: var(--success);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: white;
      font-size: 0.72rem;
      font-weight: 800;
    }

    .why-text {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text);
    }

    /* ── Final CTA ───────────────────────────────────── */
    .final-cta {
      background: var(--primary);
      color: white;
      text-align: center;
      padding: 64px 24px;
    }

    .final-cta h2 {
      font-size: clamp(1.5rem, 5vw, 2.2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 10px;
    }

    .final-cta p {
      font-size: 1rem;
      opacity: 0.8;
      margin-bottom: 32px;
    }

    /* ── Footer ──────────────────────────────────────── */
    footer {
      background: var(--bg-soft);
      border-top: 1px solid var(--border);
      padding: 24px;
      text-align: center;
    }

    .footer-links {
      display: flex;
      gap: 24px;
      justify-content: center;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .footer-links a {
      color: var(--text2);
      text-decoration: none;
      font-size: 0.875rem;
      transition: color 0.12s;
    }
    .footer-links a:hover { color: var(--primary); }

    .footer-copy { font-size: 0.8rem; color: #8AAEC8; }

    /* ── Animations ──────────────────────────────────── */
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-10px); }
    }
  </style>
</head>
<body>

