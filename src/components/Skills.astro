---
import { skillGroups, skillsIntro } from '../data/skills';
---

<section id="skills" class="py-24 px-6 max-w-3xl mx-auto">
  <h2 class="text-3xl font-bold text-slate-900 dark:text-slate-50 mb-4">
    Skills
  </h2>
  <p class="text-lg text-slate-600 dark:text-slate-300 leading-relaxed mb-12">
    {skillsIntro}
  </p>

  <div class="flex flex-col gap-10">
    {skillGroups.map(group => (
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-4">
          {group.label}
        </h3>
        <div class="flex flex-wrap gap-2">
          {group.skills.map(skill => (
            <span class="px-3 py-1.5 rounded-full text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
